{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/daily-report.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/reminders.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/sync-airtable.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/reminders_noche.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/reminders_manana.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/lista_espera_processor.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/reporte-diario",
      "dest": "api/daily-report.js"
    },
    {
      "src": "/api/recordatorios",
      "dest": "api/reminders.js"
    },
    {
      "src": "/api/reminders-noche",
      "dest": "api/reminders_noche.js"
    },
    {
      "src": "/api/reminders-manana",
      "dest": "api/reminders_manana.js"
    },
    {
      "src": "/api/lista-espera",
      "dest": "api/lista_espera_processor.js"
    },
    {
      "src": "/api/sync-airtable",
      "dest": "api/sync-airtable.js"
    },
    {
      "src": "/webhook",
      "dest": "api/webhook.js"
    },
    {
      "src": "/api/webhook",
      "dest": "api/webhook.js"
    },
    {
      "src": "/(.*)",
      "dest": "api/webhook.js"
    }
  ],
  "crons": [
    {
      "path": "/api/reporte-diario",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/recordatorios",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/reminders-noche",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/reminders-manana",
      "schedule": "0 7-9 * * *"
    },
    {
      "path": "/api/lista-espera",
      "schedule": "*/5 * * * *"
    }
  ]
}
