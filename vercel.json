{
  "version": 2,
  "functions": {
    "api/webhook.js":                { "maxDuration": 30 },
    "api/daily-report.js":           { "maxDuration": 30 },
    "api/reminders_noche.js":        { "maxDuration": 30 },
    "api/reminders_manana.js":       { "maxDuration": 30 },
    "api/lista_espera_processor.js": { "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/reporte-diario",   "dest": "api/daily-report.js" },
    { "src": "/api/reminders-noche",  "dest": "api/reminders_noche.js" },
    { "src": "/api/reminders-manana", "dest": "api/reminders_manana.js" },
    { "src": "/api/lista-espera",     "dest": "api/lista_espera_processor.js" },
    { "src": "/webhook",              "dest": "api/webhook.js" },
    { "src": "/api/webhook",          "dest": "api/webhook.js" },
    { "src": "/(.*)",                 "dest": "api/webhook.js" }
  ],
  "crons": [
    { "path": "/api/reporte-diario",   "schedule": "0 2 * * *"   },
    { "path": "/api/reminders-noche",  "schedule": "0 20 * * *"  },
    { "path": "/api/reminders-manana", "schedule": "0 7-9 * * *" },
    { "path": "/api/lista-espera",     "schedule": "*/5 * * * *" }
  ]
}
